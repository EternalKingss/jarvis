[2026-04-02 09:27:08] [powershell] [0] & {

# Kill unnecessary background processes
$toKill = @(
    "msedge",
    "msedgewebview2",
    "OneDrive",
    "PhoneExperienceHost",
    "CrossDeviceService",
    "CrossDeviceResume",
    "AMDRSServ",
    "nvcontainer",
    "NVIDIA Overlay",
    "DCv2"
)

$killed = @()
$skipped = @()

foreach ($name in $toKill) {
    $procs = Get-Process -Name "*$name*" -ErrorAction SilentlyContinue
    foreach ($proc in $procs) {
        try {
            $proc | Stop-Process -Force
            $killed += $proc.ProcessName
        } catch {
            $skipped += $proc.ProcessName
        }
    }
}

Write-Output "=== KILLED ==="
$killed | ForEach-Object { Write-Output "  ✓ $_" }
Write-Output ""
Write-Output "=== SKIPPED (access denied) ==="
$skipped | ForEach-Object { Write-Output "  ✗ $_" }

}  (cwd: C:\Users\Eternal)
[2026-04-02 09:27:15] [powershell] [0] & {

# Check current startup programs
Write-Output "=== STARTUP PROGRAMS (Registry - Current User) ==="
$startupCU = Get-ItemProperty -Path "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run" -ErrorAction SilentlyContinue
$startupCU.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
    Write-Output "  [$($_.Name)] = $($_.Value)"
}

Write-Output ""
Write-Output "=== STARTUP PROGRAMS (Registry - Local Machine) ==="
$startupLM = Get-ItemProperty -Path "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run" -ErrorAction SilentlyContinue
$startupLM.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
    Write-Output "  [$($_.Name)] = $($_.Value)"
}

Write-Output ""
Write-Output "=== STARTUP FOLDER ==="
$startupFolder = "$env:APPDATA\Microsoft\Windows\Start Menu\Programs\Startup"
Get-ChildItem $startupFolder -ErrorAction SilentlyContinue | ForEach-Object {
    Write-Output "  $($_.Name)"
}

}  (cwd: C:\Users\Eternal)
[2026-04-02 09:27:36] [powershell] [0] & {

# Remove unnecessary startup entries
$toRemove = @("OneDrive", "VoicemodV3", "Steam", "GoogleChromeAutoLaunch_B3A2F2D5E4EEA17D7B7E8B180CF10786")

Write-Output "=== REMOVING FROM STARTUP ==="
foreach ($entry in $toRemove) {
    try {
        Remove-ItemProperty -Path "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run" -Name $entry -ErrorAction Stop
        Write-Output "  ✓ Removed: $entry"
    } catch {
        Write-Output "  ✗ Not found or failed: $entry"
    }
}

# Find Claude Desktop executable
Write-Output ""
Write-Output "=== FINDING CLAUDE DESKTOP ==="
$claudePaths = @(
    "$env:LOCALAPPDATA\Programs\claude\Claude.exe",
    "$env:LOCALAPPDATA\Programs\Claude\Claude.exe",
    "$env:PROGRAMFILES\claude\Claude.exe",
    "$env:LOCALAPPDATA\AnthropicClaude\Claude.exe"
)

$claudeExe = $null
foreach ($path in $claudePaths) {
    if (Test-Path $path) {
        $claudeExe = $path
        Write-Output "  Found: $path"
        break
    }
}

# Also search via process
if (-not $claudeExe) {
    $claudeProc = Get-Process -Name "claude" -ErrorAction SilentlyContinue | Select-Object -First 1
    if ($claudeProc) {
        $claudeExe = $claudeProc.Path
        Write-Output "  Found via process: $claudeExe"
    }
}

# Add Claude to startup
if ($claudeExe) {
    Set-ItemProperty -Path "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run" -Name "Claude" -Value "`"$claudeExe`""
    Write-Output ""
    Write-Output "=== ADDED CLAUDE TO STARTUP ==="
    Write-Output "  ✓ Claude will now launch at login: $claudeExe"
} else {
    Write-Output "  Could not find Claude.exe path automatically."
}

# Show final startup state
Write-Output ""
Write-Output "=== FINAL STARTUP LIST ==="
$final = Get-ItemProperty -Path "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run" -ErrorAction SilentlyContinue
$final.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
    Write-Output "  [$($_.Name)]"
}

}  (cwd: C:\Users\Eternal)
