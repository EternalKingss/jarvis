# Jarvis MCP — Environment Variables
# Copy this file to .env and fill in your keys.

# ── Anthropic / Claude API ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs TTS ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...

# Voice ID — choose one or paste your custom cloned voice ID:
#   Adam  (deep, calm, Jarvis-like): pNInz6obpgDQGcFmaJgB
#   Josh  (warm, articulate):        TxGEqnHWrfWFTfGW9XjX
#   Rachel (clear, default):         21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Vosk speech recognition ──────────────────────────────────────────────────
# Leave blank to auto-download the small English model (~40 MB) on first run.
# Or set to an absolute path of a pre-downloaded model directory.
VOSK_MODEL_PATH=
